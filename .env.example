# Copy this file to .env and adjust if needed:  cp .env.example .env
# .env is gitignored; .env.example is the committed template.

# --- Postgres (consumed by docker-compose AND by the api) ---
# These three feed the postgres container in infra/docker-compose.yml.
POSTGRES_USER=support
POSTGRES_PASSWORD=support
POSTGRES_DB=support_widget
POSTGRES_PORT=5432

# Connection string used by the api (node-pg-migrate, pg.Pool).
# Host is localhost because the api runs on the host, not inside compose (v0).
DATABASE_URL=postgresql://support:support@localhost:5432/support_widget

# --- Redis (started in v0, used in code from v2) ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- Operator dev auth (v0 only; real Google OAuth lands in v1) ---
# Static Bearer token the dashboard sends on /operator routes. The guard compares
# it and loads the single seeded operator. Replace with real auth in v1.
OPERATOR_DEV_TOKEN=dev-operator-token

# Origin of the operator dashboard (Vite :5174). Allowed by CORS in addition to
# the projects' allowed_origins. Must match where the dashboard actually runs.
DASHBOARD_ORIGIN=http://localhost:5174
